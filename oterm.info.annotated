# ----------------------
# General / Flags
# Thanks ChatGPT for doing this so I can understand the capabilities that I need to implement
# ----------------------
oterm|odin-terminal,                # Terminal names
    am,                             # Terminal has automatic margins (wraps at right edge)
    bce,                            # Background color erase is supported
    km,                             # Has a meta key (Alt)
    mc5i,                           # Mouse tracking support (xterm-style)
    mir,                            # Can insert/delete multiple characters/lines
    msgr,                           # Safe to move cursor in standout mode
    npc,                            # No padding character needed
    xenl,                           # Avoid newline glitch at last column

# ----------------------
# Screen Dimensions / Colors
# ----------------------
    colors#8,                       # Terminal supports 8 colors
    cols#80,                        # 80 columns
    it#8,                           # Tab stops every 8 columns
    lines#24,                       # 24 lines
    pairs#64,                       # 64 color pairs for foreground/background

# ----------------------
# Character Set / ACS
# ----------------------
    acsc=``aaffggiijjkkllmmnnooppqqrrssttuuvvwwxxyyzz{{||}}~~,  # Alternate character set mapping

# ----------------------
# Bells / Visual Effects
# ----------------------
    bel=^G,                          # Bell character
    blink=\E[5m,                     # Blink attribute
    bold=\E[1m,                      # Bold attribute
    cbt=\E[Z,                         # Back tab
    civis=\E[?25l,                   # Make cursor invisible
    cnorm=\E[?12l\E[?25h,            # Make cursor normal (visible)
    cvvis=\E[?12;25h,                # Make cursor very visible (solid block)

# ----------------------
# Screen Control / Clearing
# ----------------------
    clear=\E[H\E[2J,                 # Clear screen and move cursor home
    cr=\r,                           # Carriage return
    csr=\E[%i%p1%d;%p2%dr,           # Change scroll region (top/bottom)
    ed=\E[J,                          # Erase to end of screen
    el=\E[K,                          # Erase to end of line
    el1=\E[1K,                        # Erase to beginning of line
    flash=\E[?5h$<100/>\E[?5l,       # Flash screen (visual bell)
    home=\E[H,                        # Cursor home
    ind=\n,                            # Line feed
    indn=\E[%p1%dS,                    # Scroll forward N lines
    ri=\EM,                            # Scroll backward 1 line
    rin=\E[%p1%dT,                     # Scroll backward N lines

# ----------------------
# Cursor Movement
# ----------------------
    cub=\E[%p1%dD,                    # Move cursor left N columns
    cub1=^H,                           # Move cursor left 1 column
    cuf=\E[%p1%dC,                    # Move cursor right N columns
    cuf1=\E[C,                         # Move cursor right 1 column
    cud=\E[%p1%dB,                    # Move cursor down N lines
    cud1=\n,                            # Move cursor down 1 line
    cuu=\E[%p1%dA,                    # Move cursor up N lines
    cuu1=\E[A,                          # Move cursor up 1 line
    cup=\E[%i%p1%d;%p2%dH,            # Move cursor to row/column
    hpa=\E[%i%p1%dG,                  # Move cursor to horizontal position
    vpa=\E[%i%p1%dd,                  # Move cursor to vertical position
    sc=\E7,                            # Save cursor position
    rc=\E8,                            # Restore cursor position

# ----------------------
# Line & Character Editing
# ----------------------
    dch=\E[%p1%dP,                    # Delete N characters
    dch1=\E[P,                         # Delete 1 character
    il=\E[%p1%dL,                     # Insert N lines
    il1=\E[L,                          # Insert 1 line
    ich=\E[%p1%d@,                     # Insert N characters
    ech=\E[%p1%dX,                     # Erase N characters

# ----------------------
# Text Attributes
# ----------------------
    dim=\E[2m,                        # Dim text
    rev=\E[7m,                        # Reverse video
    ritm=\E[23m,                       # Exit italic mode
    rmso=\E[27m,                        # Exit standout mode
    rmul=\E[24m,                        # Exit underline mode
    sgr0=\E(B\E[m,                     # Reset attributes
    sitm=\E[3m,                        # Enter italic
    smso=\E[7m,                        # Enter standout
    smul=\E[4m,                        # Enter underline
    bold=\E[1m,                        # Bold

# ----------------------
# Color Setting
# ----------------------
    setaf=\E[3%p1%dm,                  # Set foreground color
    setab=\E[4%p1%dm,                  # Set background color
    setf=...,                           # Conditional foreground (complex)
    setb=...,                           # Conditional background (complex)

# ----------------------
# Keypad / Function Keys
# ----------------------
    kbs=^?,                             # Backspace
    kcbt=\E[Z,                           # Back tab
    kf1=\EOP, kf2=\EOQ, kf3=\EOS, kf4=\EOR, kf5=\E[15~, kf6=\E[17~, kf7=\E[18~, kf8=\E[19~, kf9=\E[20~, kf10=\E[21~,
    kf11=\E[23~, kf12=\E[24~, kf13=\E[1;2P, kf14=\E[1;2Q, kf15=\E[1;2R, kf16=\E[1;2S, kf17=\E[15;2~, kf18=\E[17;2~,
    kf19=\E[18;2~, kf20=\E[19;2~, kf21=\E[20;2~, kf22=\E[21;2~, kf23=\E[23;2~, kf24=\E[24;2~, kf25=\E[1;5P, ...
    khome=\EOH, kEND=\E[1;2F, kHOM=\E[1;2H, kIC=\E[2;2~, kLFT=\E[1;2D, kRIT=\E[1;2C, kPRV=\E[5;2~, kNXT=\E[6;2~,
    kb2=\EOu, kbeg=\EOE, kc1=\EOq, kc3=\EOs, kdch1=\E[3~, kind=\E[1;2B, kri=\E[1;2A, kpp=\E[5~, knp=\E[6~, kich1=\E[2~,
    ka1=\EOw, ka3=\EOy, kcuu1=\EOA, kcub1=\EOD, kcud1=\EOB, kcuf1=\EOC,

# ----------------------
# Mouse / Misc
# ----------------------
    kmous=\E[<,                        # Enable mouse tracking
    mc0=\E[i, mc4=\E[4i, mc5=\E[5i,    # Media control
    meml=\El, memu=\Em, mgc=\E[?69l,  # Margin management
    nel=\EE, op=\E[39;49m,             # Next line / reset color pair
    smkx=\E[?1h\E=, rmkx=\E[?1l\E>,   # Keypad transmit mode
    smir=\E[4h, rmir=\E[4l,            # Enable/disable insert mode
    smm=\E[?1034h, rmm=\E[?1034l,      # Meta key support
    smcup=\E[?1049h\E[22;0;0t, rmcup=\E[?1049l\E[23;0;0t,  # Alternate screen buffer
    rs1=\Ec, rs2=\E[!p\E[?3;4l\E[4l\E>,  # Reset sequences
    u6=\E[%i%d;%dR, u7=\E[6n, u8=\E[?%[;0123456789]c, u9=\E[c,  # Cursor position reporting
